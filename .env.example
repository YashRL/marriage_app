# Recommended (works on IPv4 networks): Supabase shared pooler URL
SUPA_POOL_URL=postgresql://postgres.<PROJECT_REF>:<YOUR_PASSWORD>@<POOLER_HOST>:6543/postgres?sslmode=require

# Legacy direct DB URL (IPv6-only on many projects)
SUPA_BASS=postgresql://postgres:<YOUR_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
